# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# A long random string — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Port the server listens on
PORT=3001

# Dynmap base URL (used for tile proxy if CORS is blocked)
DYNMAP_BASE_URL=https://mc.westeroscraft.com
